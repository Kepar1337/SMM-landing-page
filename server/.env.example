# ===== WayForPay (з кабінету: Налаштування магазину → Реквізити мерчанта) =====
WFP_MERCHANT_ACCOUNT=your_merchant_login
WFP_MERCHANT_SECRET=your_merchant_secret_key
WFP_MERCHANT_DOMAIN=your-domain.com          # домен лендінгу БЕЗ https://

# ===== Продукт / ціна =====
PRODUCT_NAME=ЧИТ-КОД для SMM
PRICE=790
CURRENCY=UAH

# ===== Telegram / SendPulse =====
BOT_USERNAME=your_sendpulse_bot              # юзернейм бота БЕЗ @
SENDPULSE_FLOW_ID=REPLACE_FLOW_ID            # ID флоу видачі курсу (Bot structure → флоу → Link to launch a flow)
ALLOW_REENTRY=false                          # false = строго одноразово; true = дозволити тому самому покупцю повторний вхід

# ===== URL-и =====
LANDING_URL=https://your-domain.com          # де розміщено index.html
SERVER_URL=https://pay.your-domain.com       # публічний URL ЦЬОГО сервера (для returnUrl/serviceUrl)

PORT=3000
