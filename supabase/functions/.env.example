# Secrets для Edge Functions (прод: Supabase Dashboard → Edge Functions → Secrets,
# або `supabase secrets set ...`). Локально: скопіюй у supabase/functions/.env
# для `supabase functions serve --env-file supabase/functions/.env`.
# Бойові значення WayForPay сюди й у git НЕ вписувати.

# WayForPay (кабінет → Налаштування магазину → Реквізити мерчанта)
WAYFORPAY_MERCHANT=your_merchant_login
WAYFORPAY_SECRET=your_merchant_secret_key
MERCHANT_DOMAIN=smm-landing-page.vercel.app   # домен лендінгу БЕЗ https://

# Продукт (фінальні значення; на час тестів можна PRICE=1 CURRENCY=UAH)
PRICE=11
CURRENCY=USD
PRODUCT_NAME=SMM Cheat-code

# SendPulse
BOT_NAME=smmcheatcode_bot                     # системне ім'я бота (без @)
CLAIM_FLOW_ID=6a4aed70b7d1e93c8c01fcf6        # ID claim-флоу (Link to launch a flow)

# Опційно: публічний URL функцій, якщо відрізняється від SUPABASE_URL/functions/v1
# (потрібно при локальному прогоні, бо локальний SUPABASE_URL дивиться на kong).
# PUBLIC_FUNCTIONS_URL=http://127.0.0.1:54321/functions/v1

# SUPABASE_URL і SUPABASE_SERVICE_ROLE_KEY на проді інжектяться автоматично.
